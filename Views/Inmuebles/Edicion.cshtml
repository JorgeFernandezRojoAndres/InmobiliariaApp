@model InmobiliariaApp.Models.Inmueble

<h2>@(Model.Id == 0 ? "Nuevo Inmueble" : "Editar Inmueble")</h2>

<form asp-action="Guardar" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label asp-for="Direccion"></label>
        <input asp-for="Direccion" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Precio"></label>
        <input asp-for="Precio" class="form-control" type="number" />
    </div>

    <div class="form-group">
        <label asp-for="Uso"></label>
        <input asp-for="Uso" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="PropietarioId">Propietario</label>
        <select asp-for="PropietarioId" class="form-control"
                asp-items="@(new SelectList(ViewBag.Propietarios, "Id", "Nombre"))"></select>
    </div>

    <button type="submit" class="btn btn-primary">Guardar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>
